# directory aliases
if [[ -n "$CODESPACES" ]]; then
  alias w="cd /workspaces"
  alias c="cd /workspaces"
else
  alias w="cd $HOME/workspace"
  alias c="cd $HOME/workspace"
fi

# digital ocean cli
alias dlist="doctl compute droplet list"
alias ddelete="doctl compute droplet delete"

# Source file
alias sz="source ~/.zshrc"

# Rails in docker
alias rails-in-docker="docker run --rm -it -v ${PWD}:/rails -v ruby-bundle-cache:/bundle -p 3000:3000 ghcr.io/rails/cli"
